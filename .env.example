# Discord surface configuration. Shared core config does not read these values;
# the Discord entrypoint composes them with the core Pi/path config below.
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_PUBLIC_KEY=
DISCORD_GUILD_ID=
SANDI_FORUM_CHANNEL_ID=
SANDI_FORUM_CHANNEL_NAME=sandi
SANDI_STATUS_CHANNEL_ID=
SANDI_STATUS_CHANNEL_NAME=status

# GitHub surface configuration. The GitHub entrypoint shells out to an
# already-authenticated `gh` CLI user; run `gh auth login` outside Sandi.
SANDI_GH_COMMAND=gh
SANDI_GH_TIMEOUT_MS=120000
# Optional: override the login Sandi should treat as herself. If unset, the
# GitHub surface uses `gh api /user`.
# SANDI_GITHUB_LOGIN=sandi-witch
SANDI_GITHUB_POLL_INTERVAL_MS=60000
SANDI_GITHUB_MAX_NOTIFICATIONS=50
SANDI_GITHUB_NOTIFICATION_REASONS=mention,review_requested
# Set true to let a fresh state file process already-unread eligible
# notifications from before startup.
SANDI_GITHUB_PROCESS_EXISTING_NOTIFICATIONS=false

# Pi integration. Sandi shells out to an already-authenticated local `pi`
# command and does not handle OpenAI auth itself.
SANDI_PI_COMMAND=pi
SANDI_PI_MODEL=gpt-5.5
SANDI_PI_PROVIDER=openai-codex
SANDI_PI_THINKING=high
SANDI_PI_PACKAGE_MANIFEST=./config/pi-packages.json
# Optional: override Pi's agent/package directories for package setup.
# SANDI_PI_AGENT_DIR=${HOME}/.pi/agent
# SANDI_PI_PACKAGE_DIR=${HOME}/.pi/packages
SANDI_PI_SESSION_DIR=./data/pi-sessions
# Account routing is loaded by convention from ./data/config/pi-accounts.json,
# falling back to ./config/pi-accounts.json. The public repo only includes an
# example file, so account routing is disabled until a private live config exists.
SANDI_PI_JS_EXTENSION=./src/lib/pi-extension/js-run-tool.ts
SANDI_PI_MEMORY_EXTENSION=./src/lib/pi-extension/memory-tools.ts
SANDI_PI_SKILL_EXTENSION=./src/lib/pi-extension/skill-tools.ts
SANDI_PI_FEEDBACK_EXTENSION=./src/lib/pi-extension/feedback-tools.ts
SANDI_PI_POLICY_EXTENSION=./src/lib/pi-extension/policy-tools.ts
SANDI_PI_IMAGEGEN_EXTENSION=./src/lib/pi-extension/imagegen-tools.ts
SANDI_PI_TOKEN_USAGE_EXTENSION=./src/lib/pi-extension/token-usage-recorder.ts
# Optional: comma-separated full extension list. Overrides the extension vars above.
# SANDI_PI_EXTENSIONS=./src/lib/pi-extension/js-run-tool.ts,./src/lib/pi-extension/memory-tools.ts,./src/lib/pi-extension/skill-tools.ts,./src/lib/pi-extension/feedback-tools.ts,./src/lib/pi-extension/policy-tools.ts,./src/lib/pi-extension/imagegen-tools.ts,./src/lib/pi-extension/stop-sentinel.ts,./src/lib/pi-extension/token-usage-recorder.ts
SANDI_PI_TIMEOUT_MS=3600000
# Code-mode Google Maps helpers read SANDI_GOOGLE_MAPS_API_KEY or GOOGLE_MAPS_API_KEY.
# Enable Places API (New), and restrict the key to that API and Sandi's runtime.
SANDI_GOOGLE_MAPS_API_KEY=
# Image generation runs through the Pi imagegen extension and uses Pi's
# OpenAI/Codex OAuth credentials.

SANDI_DATA_DIR=./data
SANDI_CONFIG_DIR=./config
SANDI_TOKEN_USAGE_PATH=./data/provider-usage/tokens.jsonl
# Local semantic retrieval. Sandi uses this CPU embedding model for hybrid
# memory and skill search, downloading it into the data directory on first use.
SANDI_EMBEDDING_PROVIDER=local
SANDI_EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
SANDI_EMBEDDING_DTYPE=q8
SANDI_EMBEDDING_CACHE_DIR=./data/embedding-models
SANDI_EMBEDDING_BATCH_SIZE=24
# Set true after the model has been downloaded if runtime network should be off.
# SANDI_EMBEDDING_LOCAL_FILES_ONLY=false
# Private runtime config lives under ${SANDI_DATA_DIR}/config and is preferred
# over the checked-in public defaults in ${SANDI_CONFIG_DIR}, per file.
# Optional non-secret deployment note included in Sandi's runtime context.
# SANDI_ENVIRONMENT_HINT="This host is shared. Durable non-Sandi projects live outside the Sandi app and data directories unless explicitly named otherwise."
# Policies are loaded by convention from ./data/config/policies before
# ./config/policies.
SANDI_EVENTS_ROOT=./data/events
SANDI_REMINDERS_ROOT=./data/reminders
SANDI_FEEDBACK_ROOT=./data/feedback
SANDI_SKILLS_ROOT=./data/skills
SANDI_JS_RUN_ROOT=./data/js-runs
# Optional comma-separated channel names where completed reminder prompts are deleted.
# Todo/task channel prefixes are handled automatically.
# SANDI_REMINDER_CLEAN_HANDLED_CHANNELS=shopping
# Optional generic uploaded-image root passed to shared tools for the active surface.
# The Discord surface defaults its underlying attachment storage to ./data/discord-attachments.
# SANDI_SURFACE_ATTACHMENTS_ROOT=./data/surface-attachments

{
  "name": "sandi-desktop",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "description": "Sandi's desktop app: a sprite pet that lives on the desktop and opens a popover chat.",
  "author": "Jessica Black <me@jessica.black>",
  "main": "out/main/index.js",
  "scripts": {
    "icons": "node scripts/build-icons.mjs",
    "sprites": "node scripts/build-spritesheet.mjs",
    "predev": "node scripts/build-icons.mjs",
    "dev": "electron-vite dev",
    "prebuild": "node scripts/build-icons.mjs",
    "build": "electron-vite build",
    "build:mcp-smoke": "node scripts/build-icons.mjs && electron-vite build --mode mcp-smoke",
    "prepare:mcp-runtime": "node scripts/prepare-mcp-runtime.mjs",
    "verify:mcp-runtime": "node scripts/verify-mcp-runtime.mjs",
    "verify:mcp-runtime-scripts": "node scripts/verify-mcp-runtime-scripts.mjs",
    "package": "npm run build && electron-builder --win",
    "verify:packaged-mcp": "npm run build:mcp-smoke && electron-builder --win --dir --publish never && tsx --tsconfig tsconfig.node.json scripts/verify-packaged-app-mcp.ts",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "node ../node_modules/@biomejs/biome/bin/biome check --formatter-enabled=false --assist-enabled=false src scripts",
    "lint:fix": "node ../node_modules/@biomejs/biome/bin/biome check --write --formatter-enabled=false src scripts",
    "format": "node ../node_modules/@biomejs/biome/bin/biome check --write --linter-enabled=false src scripts",
    "format:check": "node ../node_modules/@biomejs/biome/bin/biome check --linter-enabled=false src scripts",
    "verify:pet-state-machine": "tsx --tsconfig tsconfig.main.json src/shared/verify-pet-state-machine.ts",
    "verify:response-buffer": "tsx --tsconfig tsconfig.main.json src/shared/verify-response-buffer.ts",
    "verify:chat-store": "tsx --tsconfig tsconfig.renderer.json src/renderer/chat/verify-store.ts",
    "verify:anchor-position": "tsx --tsconfig tsconfig.main.json src/main/verify-anchor-position.ts",
    "verify:renderer-url": "tsx --tsconfig tsconfig.main.json src/main/verify-renderer-url.ts",
    "verify:window-navigation": "tsx --tsconfig tsconfig.main.json src/main/verify-window-navigation.ts && tsx --tsconfig tsconfig.main.json src/main/verify-app-hardening.ts && tsx --tsconfig tsconfig.renderer.json src/renderer/chat/verify-external-links.tsx",
    "verify:ipc-schemas": "tsx --tsconfig tsconfig.main.json src/main/verify-ipc-schemas.ts",
    "verify:attachment-staging": "tsx --tsconfig tsconfig.main.json src/main/verify-attachment-staging.ts",
    "verify:link-manager": "tsx --tsconfig tsconfig.main.json src/main/verify-link-manager.ts",
    "verify:mcp-host": "tsx --tsconfig tsconfig.main.json src/main/mcp/verify-mcp-host.ts",
    "verify:mcp-bridge-smoke": "tsx --tsconfig tsconfig.main.json src/main/mcp/packaged-smoke.ts src/main/mcp/fixtures/stdio-server.mjs",
    "verify:transcript-store": "tsx --tsconfig tsconfig.main.json src/main/verify-transcript-store.ts",
    "verify:turn-manager-queue": "tsx --tsconfig tsconfig.main.json src/main/verify-turn-manager-queue.ts",
    "verify:wander-scheduler": "tsx --tsconfig tsconfig.main.json src/main/verify-wander-scheduler.ts",
    "verify:idle-fidget-scheduler": "tsx --tsconfig tsconfig.main.json src/main/verify-idle-fidget-scheduler.ts",
    "verify:turn-pipeline": "tsx --tsconfig tsconfig.main.json src/main/verify-turn-pipeline.ts",
    "verify:auto-titler": "tsx --tsconfig tsconfig.main.json src/main/verify-auto-titler.ts",
    "verify:update-state": "tsx --tsconfig tsconfig.main.json src/main/verify-update-state.ts",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run verify:mcp-runtime-scripts && npm run verify:pet-state-machine && npm run verify:response-buffer && npm run verify:chat-store && npm run verify:anchor-position && npm run verify:renderer-url && npm run verify:window-navigation && npm run verify:ipc-schemas && npm run verify:attachment-staging && npm run verify:link-manager && npm run verify:mcp-host && npm run verify:mcp-bridge-smoke && npm run verify:transcript-store && npm run verify:turn-manager-queue && npm run verify:wander-scheduler && npm run verify:idle-fidget-scheduler && npm run verify:turn-pipeline && npm run verify:auto-titler && npm run verify:update-state"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cross-spawn": "^7.0.6",
    "motion": "^12.42.2",
    "re2-wasm": "^1.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "43.1.1",
    "electron-builder": "^26.15.3",
    "electron-updater": "^6.8.9",
    "electron-vite": "^5.0.0",
    "highlight.js": "^11.11.1",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "zod": "^4.3.6"
  }
}

{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "types": ["node"],
    "paths": {
      "@/*": ["../src/*"],
      "@sandi-server/*": ["../src/*"],
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": ["electron.vite.config.ts", "scripts/**/*"],
  "exclude": ["node_modules"]
}

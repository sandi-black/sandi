{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sandi.local/config/pi-accounts.schema.json",
  "title": "Sandi Pi account routing",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "accounts", "routes"],
  "properties": {
    "version": {
      "const": 1
    },
    "accounts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/account"
      }
    },
    "routes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/route"
      }
    }
  },
  "$defs": {
    "account": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "agentDir": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "thinking": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "route": {
      "type": "object",
      "additionalProperties": false,
      "required": ["identityId", "accountId"],
      "properties": {
        "identityId": {
          "type": "string",
          "minLength": 1
        },
        "accountId": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}

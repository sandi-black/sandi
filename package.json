    "dev": "tsx src/host/index.ts",
    "dev:discord": "tsx src/surfaces/discord/index.ts",
    "dev:github": "tsx src/surfaces/github/index.ts",
    "dev:api": "tsx src/surfaces/api/index.ts",
    "start": "tsx src/host/index.ts",
    "start:discord": "tsx src/surfaces/discord/index.ts",
    "start:github": "tsx src/surfaces/github/index.ts",
    "start:api": "tsx src/surfaces/api/index.ts",
    "api:enroll": "tsx src/surfaces/api/auth/enroll.ts",
    "client": "tsx src/surfaces/api/client/index.ts",
    "commands:sync": "tsx src/surfaces/discord/register-commands.ts",
    "hooks:install": "git config core.hooksPath .githooks",
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && git config core.hooksPath .githooks || true",
    "verify:discord-scheduled-inputs": "tsx src/surfaces/discord/runtime/verify-scheduled-inputs.ts",
    "verify:attachment-store": "tsx src/surfaces/api/attachments/verify-attachment-store.ts",
    "verify:attachment-routes": "tsx src/surfaces/api/attachments/verify-attachment-routes.ts",
    "verify:attach-to-reply": "tsx src/surfaces/api/pi-extension/verify-attach-to-reply.ts"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.80.3",
    "@earendil-works/pi-coding-agent": "0.80.3",
    "@huggingface/transformers": "^4.2.0",
    "croner": "^10.0.1",
    "discord.js": "^14.19.3",
    "dotenv": "^17.4.2",
    "tsx": "^4.23.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@types/node": "^26.1.0",
    "biome-plugin-no-type-assertion": "^1.1.1",
    "oxfmt": "^0.58.0",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "discord.js": {
      "undici": "6.27.0",
      "@discordjs/rest": {
        "undici": "6.27.0"
      }
    }
  }
}

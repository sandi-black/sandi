{
  "name": "sandi",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "description": "A customizable, self-extending household agent backed by a Pi gateway.",
  "workspaces": [
    "app"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "node node_modules/@biomejs/biome/bin/biome check --formatter-enabled=false --assist-enabled=false .",
    "lint:fix": "node node_modules/@biomejs/biome/bin/biome check --write --formatter-enabled=false .",
    "format": "node node_modules/@biomejs/biome/bin/biome check --write --linter-enabled=false . && oxfmt --write '**/*.{md,mdx}' --no-error-on-unmatched-pattern",
    "format:check": "node node_modules/@biomejs/biome/bin/biome check --linter-enabled=false . && oxfmt --check '**/*.{md,mdx}' --no-error-on-unmatched-pattern",
    "setup:pi": "tsx src/lib/provider/setup-pi.ts",
    "verify:platform-dirs": "tsx src/lib/config/verify-platform-dirs.ts",
    "verify:config-overlays": "tsx src/lib/config/verify-config-overlays.ts",
    "verify:identity-memory": "tsx src/lib/identity/verify-identity-memory.ts",
    "verify:auth-resolver": "tsx src/lib/identity/verify-auth-resolver.ts",
    "verify:pi-harness": "tsx src/lib/provider/verify-pi-harness.ts",
    "verify:pi-account-routing": "tsx src/lib/provider/verify-pi-account-routing.ts",
    "verify:pi-runtime-setup": "tsx src/lib/provider/verify-pi-runtime-setup.ts",
    "verify:pi-extension-load": "tsx src/lib/provider/verify-pi-extension-load.ts",
    "verify:embedding-index": "tsx src/lib/retrieval/verify-embedding-index.ts",
    "verify:feedback-tools": "tsx src/lib/pi-extension/verify-feedback-tools.ts",
    "verify:source-grounding": "tsx src/lib/context/verify-source-grounding.ts",
    "verify:conversation-title": "tsx src/lib/conversations/verify-title.ts",
    "verify:discord-thread-title": "tsx src/surfaces/discord/bot/verify-thread-title.ts",
    "verify:discord-passive-gate": "tsx src/surfaces/discord/bot/verify-passive-reply-gate.ts",
    "verify:discord-ignored-channels": "tsx src/surfaces/discord/bot/verify-ignored-channels.ts",
    "verify:discord-delivery": "tsx src/surfaces/discord/discord/verify-delivery-instructions.ts",
    "verify:discord-conversations": "tsx src/surfaces/discord/discord/verify-conversations.ts",
    "verify:discord-runtime-targets": "tsx src/surfaces/discord/runtime/verify-runtime-targets.ts",
    "verify:github-bot": "tsx src/surfaces/github/bot/verify-github-bot.ts",

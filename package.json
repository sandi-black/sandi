    "verify:github-conversations": "tsx src/surfaces/github/github/verify-conversations.ts",
    "verify:github-gh-cli": "tsx src/surfaces/github/github/verify-gh-cli.ts",
    "verify:github-notifications": "tsx src/surfaces/github/github/verify-notifications.ts",
    "verify:github-state": "tsx src/surfaces/github/github/verify-state.ts",
    "verify:api-bot": "tsx src/surfaces/api/bot/verify-api-bot.ts",
    "verify:api-rate-limiter": "tsx src/surfaces/api/auth/verify-rate-limiter.ts",
    "verify:tool-broker": "tsx src/surfaces/api/devices/verify-tool-broker.ts",
    "verify:desktop-hands": "tsx src/surfaces/api/devices/verify-desktop-hands.ts",
    "verify:desktop-state": "tsx src/surfaces/api/client/verify-desktop-state.ts",
    "verify:desktop-hands-lease": "tsx src/lib/provider/verify-desktop-hands-lease.ts",
    "verify:local-exec-tools": "tsx src/surfaces/api/pi-extension/verify-local-exec-tools.ts",

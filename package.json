    "verify:credentials": "tsx src/surfaces/api/client/verify-credentials.ts",
    "verify:client-pairing": "tsx src/surfaces/api/client/verify-pairing.ts",
    "verify:discord-auth": "tsx src/surfaces/discord/bot/verify-device-auth.ts",
    "verify:event-creator-routing": "tsx src/surfaces/discord/events/verify-event-creator-routing.ts",
    "verify:token-usage": "tsx src/lib/provider/verify-token-usage.ts",
    "verify:managed-write": "tsx src/lib/state/verify-managed-write.ts",
    "verify:pairing": "tsx src/lib/pairing/verify-pairing.ts",

{
  "name": "sandi",
  "version": "0.1.0",
  "private": true,
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "description": "A customizable, self-extending household agent backed by a Pi gateway.",
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "node node_modules/@biomejs/biome/bin/biome check --formatter-enabled=false --assist-enabled=false .",
    "lint:fix": "node node_modules/@biomejs/biome/bin/biome check --write --formatter-enabled=false .",
    "format": "node node_modules/@biomejs/biome/bin/biome check --write --linter-enabled=false . && oxfmt --write '**/*.{md,mdx}' --no-error-on-unmatched-pattern",
    "format:check": "node node_modules/@biomejs/biome/bin/biome check --linter-enabled=false . && oxfmt --check '**/*.{md,mdx}' --no-error-on-unmatched-pattern",
    "setup:pi": "tsx src/lib/provider/setup-pi.ts",
    "verify:config-overlays": "tsx src/lib/config/verify-config-overlays.ts",
    "verify:identity-memory": "tsx src/lib/identity/verify-identity-memory.ts",
    "verify:pi-harness": "tsx src/lib/provider/verify-pi-harness.ts",
    "verify:pi-account-routing": "tsx src/lib/provider/verify-pi-account-routing.ts",
    "verify:pi-runtime-setup": "tsx src/lib/provider/verify-pi-runtime-setup.ts",
    "verify:pi-extension-load": "tsx src/lib/provider/verify-pi-extension-load.ts",
    "verify:embedding-index": "tsx src/lib/retrieval/verify-embedding-index.ts",
    "verify:feedback-tools": "tsx src/lib/pi-extension/verify-feedback-tools.ts",
    "verify:source-grounding": "tsx src/lib/context/verify-source-grounding.ts",
    "verify:discord-thread-title": "tsx src/surfaces/discord/bot/verify-thread-title.ts",
    "verify:discord-passive-gate": "tsx src/surfaces/discord/bot/verify-passive-reply-gate.ts",
    "verify:discord-ignored-channels": "tsx src/surfaces/discord/bot/verify-ignored-channels.ts",
    "verify:discord-delivery": "tsx src/surfaces/discord/discord/verify-delivery-instructions.ts",
    "verify:discord-conversations": "tsx src/surfaces/discord/discord/verify-conversations.ts",
    "verify:github-bot": "tsx src/surfaces/github/bot/verify-github-bot.ts",
    "verify:github-conversations": "tsx src/surfaces/github/github/verify-conversations.ts",
    "verify:github-gh-cli": "tsx src/surfaces/github/github/verify-gh-cli.ts",
    "verify:github-notifications": "tsx src/surfaces/github/github/verify-notifications.ts",
    "verify:github-state": "tsx src/surfaces/github/github/verify-state.ts",
    "verify:event-creator-routing": "tsx src/surfaces/discord/events/verify-event-creator-routing.ts",
    "verify:token-usage": "tsx src/lib/provider/verify-token-usage.ts",
    "verify:migration": "tsx src/lib/migrations/verify-data-dir-migration.ts",
    "verify:surface-boundary": "tsx src/lib/verification/verify-surface-boundary.ts",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run verify:config-overlays && npm run verify:identity-memory && npm run verify:pi-harness && npm run verify:pi-account-routing && npm run verify:pi-runtime-setup && npm run verify:pi-extension-load && npm run verify:embedding-index && npm run verify:feedback-tools && npm run verify:source-grounding && npm run verify:discord-thread-title && npm run verify:discord-passive-gate && npm run verify:discord-ignored-channels && npm run verify:discord-delivery && npm run verify:discord-conversations && npm run verify:github-bot && npm run verify:github-conversations && npm run verify:github-gh-cli && npm run verify:github-notifications && npm run verify:github-state && npm run verify:event-creator-routing && npm run verify:token-usage && npm run verify:migration && npm run verify:surface-boundary",
    "dev": "tsx src/surfaces/discord/index.ts",
    "dev:github": "tsx src/surfaces/github/index.ts",
    "start": "tsx src/surfaces/discord/index.ts",
    "start:github": "tsx src/surfaces/github/index.ts",
    "commands:sync": "tsx src/surfaces/discord/register-commands.ts",
    "hooks:install": "git config core.hooksPath .githooks",
    "prepare": "git rev-parse --git-dir >/dev/null 2>&1 && git config core.hooksPath .githooks || true"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "0.79.10",
    "@earendil-works/pi-coding-agent": "0.79.10",
    "@huggingface/transformers": "^4.2.0",
    "croner": "^10.0.1",
    "discord.js": "^14.19.3",
    "dotenv": "^17.4.2",
    "tsx": "^4.22.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^25.9.3",
    "biome-plugin-no-type-assertion": "^1.1.1",
    "oxfmt": "^0.56.0",
    "typescript": "^6.0.3"
  }
}
